# ═══════════════════════════════════════════════════════
# Rising Cakes Mexicali — Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# These are NOT needed for the demo/simulation mode.

# Payment Gateway (Stripe)
# VITE_STRIPE_PUBLIC_KEY=pk_test_...

# Payment Gateway (Conekta — Mexico)
# VITE_CONEKTA_PUBLIC_KEY=key_...

# API Base URL (for future backend)
# VITE_API_URL=https://api.risingcakes.mx

# Google Maps (for store locator)
# VITE_GOOGLE_MAPS_KEY=AIza...

# WhatsApp Business
VITE_WHATSAPP_NUMBER=5216865551234
